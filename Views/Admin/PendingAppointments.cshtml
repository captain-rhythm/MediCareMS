@model IEnumerable<MediCareMS.Models.Entities.Appointment.Appointment>
@{
    ViewData["Title"] = "Pending Appointments";
    Layout = "_Layout";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Pending Appointments</h2>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }

    <div class="card shadow-sm">
        <div class="card-body">
            @if (!Model.Any())
            {
                <p class="text-muted">No pending appointments.</p>
            }
            else
            {
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>No.</th>
                            <th>Patient</th>
                            <th>Doctor</th>
                            <th>Date & Time</th>
                            <th>Complaint</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var appt in Model)
                        {
                            <tr>
                                <td>@appt.AppointmentNo</td>
                                <td>@appt.Patient.FullName</td>
                                <td>@appt.Doctor.FullName</td>
                                <td>@appt.AppointmentDate.ToString("dd MMM yyyy") at @appt.AppointmentTime.ToString("hh:mm tt")</td>
                                <td>@(string.IsNullOrEmpty(appt.ChiefComplaint) ? "N/A" : appt.ChiefComplaint)</td>
                                <td>
                                    <form asp-action="ApproveAppointment" asp-route-id="@appt.Id" method="post" style="display:inline;">
                                        <button type="submit" class="btn btn-sm btn-success"><i class="fas fa-check"></i> Accept</button>
                                    </form>
                                    <!-- Decline logic would go here -->
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>
</div>
