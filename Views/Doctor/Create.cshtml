@model MediCareMS.Models.ViewModels.Doctor.DoctorCreateEditViewModel
@{ ViewData["Title"] = "Add Doctor"; }

<div class="page-header">
    <h2><i class="fas fa-user-plus"></i> Add New Doctor</h2>
    <a asp-action="Index" class="btn btn-outline"><i class="fas fa-arrow-left"></i> Back</a>
</div>
<div class="card">
    <form asp-action="Create" method="post" enctype="multipart/form-data" class="form-grid">
        <div asp-validation-summary="ModelOnly" class="validation-summary"></div>
        <div class="form-row">
            <div class="form-group"><label class="form-label">Full Name *</label><input asp-for="FullName" class="form-control" /><span asp-validation-for="FullName" class="field-error"></span></div>
            <div class="form-group"><label class="form-label">Department *</label><select asp-for="DepartmentId" asp-items="Model.Departments" class="form-control"><option value="">-- Select --</option></select><span asp-validation-for="DepartmentId" class="field-error"></span></div>
        </div>
        <div class="form-row">
            <div class="form-group"><label class="form-label">Specialization *</label><select asp-for="SpecializationId" asp-items="Model.Specializations" class="form-control"><option value="">-- Select --</option></select><span asp-validation-for="SpecializationId" class="field-error"></span></div>
            <div class="form-group"><label class="form-label">Qualification</label><input asp-for="Qualification" class="form-control" /></div>
        </div>
        <div class="form-row">
            <div class="form-group"><label class="form-label">Experience (Years)</label><input asp-for="ExperienceYears" type="number" class="form-control" /></div>
            <div class="form-group"><label class="form-label">BMDC Reg No</label><input asp-for="BmdcRegNo" class="form-control" /></div>
        </div>
        <div class="form-row">
            <div class="form-group"><label class="form-label">Mobile *</label><input asp-for="MobileNumber" class="form-control" /></div>
            <div class="form-group"><label class="form-label">Email</label><input asp-for="Email" type="email" class="form-control" /></div>
        </div>
        <div class="form-row">
            <div class="form-group"><label class="form-label">Consultation Fee (৳) *</label><input asp-for="ConsultationFee" type="number" step="0.01" class="form-control" /></div>
            <div class="form-group"><label class="form-label">Status</label><select asp-for="Status" asp-items="Html.GetEnumSelectList<MediCareMS.Models.Enums.DoctorStatus>()" class="form-control"></select></div>
        </div>
        <div class="form-group"><label class="form-label">Chamber Address</label><input asp-for="ChamberAddress" class="form-control" /></div>
        <div class="form-group"><label class="form-label">Bio</label><textarea asp-for="Bio" class="form-control" rows="3"></textarea></div>
        <div class="form-group"><label class="form-label">Profile Photo</label><input asp-for="ProfileImage" type="file" class="form-control" accept="image/*" /></div>
        <div class="form-actions">
            <button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> Save Doctor</button>
            <a asp-action="Index" class="btn btn-outline">Cancel</a>
        </div>
    </form>
</div>
