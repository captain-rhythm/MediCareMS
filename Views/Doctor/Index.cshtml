@model IEnumerable<MediCareMS.Models.ViewModels.Doctor.DoctorListViewModel>
@using MediCareMS.Models.Enums
@using System.Text.Json
@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery
@{ ViewData["Title"] = "Doctors"; }

@{
    var doctorJson = JsonSerializer.Serialize(Model.Select(d => new {
        id             = d.Id,
        doctorNo       = d.DoctorNo,
        fullName       = d.FullName,
        department     = d.Department,
        specialization = d.Specialization,
        qualification  = d.Qualification  ?? "—",
        experience     = d.ExperienceYears ?? 0,
        fee            = d.ConsultationFee,
        status         = d.Status.ToString(),
        editUrl        = Url.Action("Edit",   "Doctor", new { id = d.Id }),
        deleteUrl      = Url.Action("Delete", "Doctor", new { id = d.Id })
    }));
    var antiforgeryToken = Antiforgery.GetAndStoreTokens(Context).RequestToken;
}

<div class="page-header">
    <h2><i class="fas fa-user-md"></i> Doctor Management</h2>
    <a asp-action="Create" class="btn btn-primary"><i class="fas fa-plus"></i> Add Doctor</a>
</div>

<div class="card" style="padding:0;overflow:hidden;">
    <div id="doctor-table"></div>
</div>

@section Scripts {
<link href="https://unpkg.com/tabulator-tables@6.3.0/dist/css/tabulator.min.css" rel="stylesheet"/>
<script src="https://unpkg.com/tabulator-tables@6.3.0/dist/js/tabulator.min.js"></script>
<style>
/* ── Tabulator skin – Doctor Management ── */
#doctor-table .tabulator {
    border: none !important;
    background: transparent !important;
    font-family: 'Inter', sans-serif !important;
    font-size: 13.5px !important;
    color: var(--text-primary, #1e293b) !important;
    border-radius: 0 0 12px 12px !important;
    overflow: hidden !important;
}
#doctor-table .tabulator-header {
    background: linear-gradient(135deg, #0ea5e9 0%, #6366f1 50%, #8b5cf6 100%) !important;
    border-bottom: none !important;
}
#doctor-table .tabulator-col {
    background: transparent !important;
    border-right: 1px solid rgba(255,255,255,0.15) !important;
}
#doctor-table .tabulator-col-title {
    color: #ffffff !important;
    font-weight: 700 !important;
    font-size: 12px !important;
    letter-spacing: .6px !important;
    text-transform: uppercase !important;
}
#doctor-table .tabulator-col .tabulator-col-sorter .tabulator-arrow { border-top-color: rgba(255,255,255,0.7) !important; border-bottom-color: rgba(255,255,255,0.7) !important; }
#doctor-table .tabulator-col-content { padding: 10px 12px 4px !important; }

/* Header filter inputs */
#doctor-table .tabulator-header-filter input,
#doctor-table .tabulator-header-filter select {
    background: #ffffff !important;
    border: 1.5px solid rgba(255,255,255,0.6) !important;
    border-radius: 6px !important;
    padding: 4px 8px !important;
    font-size: 11.5px !important;
    color: #1e293b !important;
    width: 100% !important;
    outline: none !important;
    transition: border-color .2s !important;
}
#doctor-table .tabulator-header-filter input:focus,
#doctor-table .tabulator-header-filter select:focus { border-color: #0ea5e9 !important; }

/* Rows */
#doctor-table .tabulator-row { border-bottom: 1px solid #f1f5f9 !important; transition: background .15s; }
#doctor-table .tabulator-row:hover { background: #f0f9ff !important; }
#doctor-table .tabulator-row.tabulator-row-even { background: #f8fafc; }
#doctor-table .tabulator-cell { padding: 10px 12px !important; vertical-align: middle !important; }

/* Badges */
.doc-badge { display:inline-block; padding:2px 9px; border-radius:20px; font-size:11.5px; font-weight:600; }
.doc-badge-no   { background:#ede9fe; color:#6d28d9; }
.doc-badge-dept { background:#e0f2fe; color:#0369a1; }
.doc-badge-spec { background:#f0fdf4; color:#166534; }
.doc-badge-avail { background:#dcfce7; color:#166534; }
.doc-badge-leave  { background:#fef9c3; color:#854d0e; }
.doc-badge-inactive { background:#fee2e2; color:#991b1b; }
.doc-fee  { font-weight:700; color:#0ea5e9; }

/* Actions */
.doc-actions { display:flex; gap:6px; justify-content:center; }
.doc-btn {
    display:inline-flex; align-items:center; justify-content:center;
    width:30px; height:30px; border-radius:7px;
    border:none; cursor:pointer; text-decoration:none;
    transition: transform .15s, box-shadow .15s;
}
.doc-btn:hover { transform:translateY(-2px); box-shadow:0 4px 12px rgba(0,0,0,.12); }
.doc-btn-edit   { background:#e0f2fe; color:#0369a1; }
.doc-btn-delete { background:#fee2e2; color:#dc2626; }

/* Pagination */
#doctor-table .tabulator-footer { background:#fff; border-top:1px solid #e2e8f0; padding:8px 12px; }
#doctor-table .tabulator-page {
    border:1.5px solid rgba(14,165,233,0.25) !important;
    border-radius:7px !important; padding:4px 10px !important;
    font-size:12px !important; font-family:'Inter',sans-serif !important;
    color:#374151 !important; background:#fff !important;
    cursor:pointer; transition:all .15s !important; margin:0 2px !important;
}
#doctor-table .tabulator-page:hover { background:#e0f2fe !important; transform:translateY(-1px); }
#doctor-table .tabulator-page.active {
    background: linear-gradient(135deg,#0ea5e9,#6366f1) !important;
    border-color:transparent !important; color:#fff !important;
    box-shadow:0 4px 12px rgba(14,165,233,.35) !important;
}
#doctor-table .tabulator-page[disabled] { opacity:.35; cursor:not-allowed; }
#doctor-table .tabulator-page-size {
    border:1.5px solid rgba(14,165,233,0.2) !important;
    border-radius:8px; padding:4px 8px;
    font-size:12px; font-family:'Inter',sans-serif;
    color:#374151; background:#fff; cursor:pointer;
}
/* Empty state */
.doc-empty { text-align:center; padding:52px 20px; color:#94a3b8; font-size:14px; }
.doc-empty i { font-size:40px; margin-bottom:10px; opacity:.4; display:block; }
</style>

<script>
(function(){
    const doctors = @Html.Raw(doctorJson);
    const AF_TOKEN = "@antiforgeryToken";

    /* ── Formatters ── */
    const fmtDocNo = (cell) =>
        `<span class="doc-badge doc-badge-no">${cell.getValue()}</span>`;

    const fmtName = (cell) =>
        `<strong style="color:var(--text-primary,#1e293b)">${cell.getValue()}</strong>`;

    const fmtDept = (cell) =>
        `<span class="doc-badge doc-badge-dept">${cell.getValue()}</span>`;

    const fmtSpec = (cell) =>
        `<span class="doc-badge doc-badge-spec">${cell.getValue()}</span>`;

    const fmtFee = (cell) =>
        `<span class="doc-fee">৳${Number(cell.getValue()).toLocaleString()}</span>`;

    const fmtExp = (cell) =>
        `<span style="color:#475569;font-weight:600">${cell.getValue()} yrs</span>`;

    const fmtStatus = (cell) => {
        const v = cell.getValue();
        const cls = v === 'Available' ? 'doc-badge-avail'
                  : v === 'OnLeave'   ? 'doc-badge-leave'
                  : 'doc-badge-inactive';
        const label = v === 'OnLeave' ? 'On Leave' : v;
        return `<span class="doc-badge ${cls}">${label}</span>`;
    };

    const fmtActions = (cell) => {
        const row = cell.getRow().getData();
        return `<div class="doc-actions">
            <a href="${row.editUrl}" class="doc-btn doc-btn-edit" title="Edit"><i class="fas fa-edit"></i></a>
            <button class="doc-btn doc-btn-delete" title="Delete"
                onclick="deleteDoctor('${row.deleteUrl}')"><i class="fas fa-trash"></i></button>
        </div>`;
    };

    /* ── Status dropdown options ── */
    const statusValues = [
        {label:"All Status",   value:""},
        {label:"Available",    value:"Available"},
        {label:"On Leave",     value:"OnLeave"},
        {label:"Inactive",     value:"Inactive"},
    ];

    /* ── Unique department list ── */
    const deptSet = [...new Set(doctors.map(d => d.department))].sort();
    const deptValues = [{label:"All Departments", value:""}, ...deptSet.map(d=>({label:d, value:d}))];

    /* ── Initialize Tabulator ── */
    new Tabulator("#doctor-table", {
        data: doctors,
        layout: "fitColumns",
        responsiveLayout: "collapse",
        pagination: true,
        paginationMode: "local",
        paginationSize: 10,
        paginationSizeSelector: [5, 10, 20, 50],
        movableColumns: false,
        sortMode: "local",
        filterMode: "local",
        placeholder: `<div class="doc-empty"><i class="fas fa-user-md"></i>No doctors found.</div>`,
        columns: [
            {
                title: "#", field: "id", width: 55,
                hozAlign: "center", headerHozAlign: "center",
                headerFilter: false, headerSort: false,
                formatter: (cell) => {
                    const rows = cell.getTable().getRows("active");
                    const idx  = rows.indexOf(cell.getRow());
                    return `<span style="color:#94a3b8;font-weight:600;font-size:12px">${idx+1}</span>`;
                }
            },
            {
                title: "Doctor No", field: "doctorNo", minWidth: 130,
                headerFilter: "input", headerFilterPlaceholder: "Search…",
                formatter: fmtDocNo, sorter: "string"
            },
            {
                title: "Full Name", field: "fullName", minWidth: 170,
                headerFilter: "input", headerFilterPlaceholder: "Search…",
                formatter: fmtName, sorter: "string"
            },
            {
                title: "Department", field: "department", minWidth: 150,
                headerFilter: "select",
                headerFilterParams: { values: deptValues },
                headerFilterFunc: "=",
                formatter: fmtDept, sorter: "string"
            },
            {
                title: "Specialization", field: "specialization", minWidth: 180,
                headerFilter: "input", headerFilterPlaceholder: "Search…",
                formatter: fmtSpec, sorter: "string"
            },
            {
                title: "Qualification", field: "qualification", minWidth: 160,
                headerFilter: "input", headerFilterPlaceholder: "Search…",
                sorter: "string"
            },
            {
                title: "Exp.", field: "experience", width: 80,
                hozAlign: "center", headerHozAlign: "center",
                headerFilter: false,
                formatter: fmtExp, sorter: "number"
            },
            {
                title: "Fee (৳)", field: "fee", width: 100,
                hozAlign: "right", headerHozAlign: "right",
                headerFilter: false,
                formatter: fmtFee, sorter: "number"
            },
            {
                title: "Status", field: "status", width: 120,
                hozAlign: "center", headerHozAlign: "center",
                headerFilter: "select",
                headerFilterParams: { values: statusValues },
                headerFilterFunc: "=",
                formatter: fmtStatus, sorter: "string"
            },
            {
                title: "Actions", field: "id", width: 100,
                hozAlign: "center", headerHozAlign: "center",
                headerFilter: false, headerSort: false,
                formatter: fmtActions
            }
        ]
    });

    /* ── Delete handler ── */
    window.deleteDoctor = function(url) {
        if (!confirm('Are you sure you want to remove this doctor?')) return;
        const form = document.createElement('form');
        form.method = 'POST';
        form.action = url;
        const tok = document.createElement('input');
        tok.type = 'hidden'; tok.name = '__RequestVerificationToken'; tok.value = AF_TOKEN;
        form.appendChild(tok);
        document.body.appendChild(form);
        form.submit();
    };
})();
</script>
}
