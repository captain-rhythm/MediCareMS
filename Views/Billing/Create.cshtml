@model MediCareMS.Models.ViewModels.Billing.CreateInvoiceViewModel
@{
    ViewData["Title"] = "Create Invoice";
    Layout = "_Layout";
}

<div class="page-header">
    <h2><i class="fas fa-file-invoice"></i> Create Invoice</h2>
    <a asp-action="Index" class="btn btn-outline"><i class="fas fa-arrow-left"></i> Back to List</a>
</div>

<div class="card">
    <div class="card-body">
        <form asp-action="Create" method="post" id="invoiceForm">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="row mb-4">
                <div class="col-md-4 form-group">
                    <label asp-for="AppointmentId" class="form-label">Linked Appointment <span class="text-danger">*</span></label>
                    <select asp-for="AppointmentId" class="form-control" id="aptSelect">
                        <option value="">-- Select Appointment --</option>
                        @foreach (var apt in ViewBag.Appointments)
                        {
                            <option value="@apt.Id" data-patient="@apt.PatientId" data-doctor="@apt.DoctorId">@apt.AppointmentNo - @apt.Patient.FullName (@apt.AppointmentDate.ToString("dd MMM yyyy"))</option>
                        }
                    </select>
                    <span asp-validation-for="AppointmentId" class="field-error"></span>
                </div>
                <div class="col-md-4 form-group">
                    <label asp-for="PatientId" class="form-label">Patient <span class="text-danger">*</span></label>
                    <select asp-for="PatientId" class="form-control" id="patientSelect">
                        <option value="">-- Select Patient --</option>
                        @foreach (var p in ViewBag.Patients)
                        {
                            <option value="@p.Id">@p.FullName</option>
                        }
                    </select>
                    <span asp-validation-for="PatientId" class="field-error"></span>
                </div>
                <div class="col-md-4 form-group">
                    <label asp-for="DoctorId" class="form-label">Doctor <span class="text-danger">*</span></label>
                    <select asp-for="DoctorId" class="form-control" id="doctorSelect">
                        <option value="">-- Select Doctor --</option>
                        @foreach (var d in ViewBag.Doctors)
                        {
                            <option value="@d.Id" data-fee="@d.ConsultationFee">@d.FullName</option>
                        }
                    </select>
                    <span asp-validation-for="DoctorId" class="field-error"></span>
                </div>
            </div>

            <h4 class="section-heading mt-4 mb-3">Fixed Charges</h4>
            <div class="row mb-4">
                <div class="col-md-3 form-group">
                    <label asp-for="ConsultationFee" class="form-label">Consultation Fee (৳)</label>
                    <input asp-for="ConsultationFee" type="number" step="0.01" class="form-control calc-field" id="consultationFee" />
                    <span asp-validation-for="ConsultationFee" class="field-error"></span>
                </div>
                <div class="col-md-3 form-group">
                    <label asp-for="TestFee" class="form-label">Lab / Test Fee (৳)</label>
                    <input asp-for="TestFee" type="number" step="0.01" class="form-control calc-field" />
                    <span asp-validation-for="TestFee" class="field-error"></span>
                </div>
                <div class="col-md-3 form-group">
                    <label asp-for="OtherCharges" class="form-label">Other Charges (৳)</label>
                    <input asp-for="OtherCharges" type="number" step="0.01" class="form-control calc-field" />
                    <span asp-validation-for="OtherCharges" class="field-error"></span>
                </div>
                <div class="col-md-3 form-group">
                    <label asp-for="DiscountPercent" class="form-label">Discount (%)</label>
                    <input asp-for="DiscountPercent" type="number" step="0.01" max="100" class="form-control calc-field" />
                    <span asp-validation-for="DiscountPercent" class="field-error"></span>
                </div>
            </div>

            <h4 class="section-heading mt-4 mb-3">Extra Items</h4>
            <div class="table-responsive mb-4">
                <table class="table" id="itemsTable">
                    <thead>
                        <tr>
                            <th>Description</th>
                            <th width="150">Unit Price (৳)</th>
                            <th width="100">Qty</th>
                            <th width="150">Total</th>
                            <th width="80"></th>
                        </tr>
                    </thead>
                    <tbody>
                        <!-- Items will be added here -->
                    </tbody>
                </table>
                <button type="button" class="btn btn-sm btn-outline mt-2" onclick="addItem()"><i class="fas fa-plus"></i> Add Item</button>
            </div>

            <div class="row">
                <div class="col-md-6">
                    <div class="form-group mb-3">
                        <label asp-for="Notes" class="form-label">Internal Notes / Terms</label>
                        <textarea asp-for="Notes" class="form-control" rows="3"></textarea>
                    </div>
                    <div class="form-group">
                        <label asp-for="DueDate" class="form-label">Due Date</label>
                        <input asp-for="DueDate" type="date" class="form-control" />
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="card bg-light ml-auto" style="max-width: 350px;">
                        <div class="card-body p-3">
                            <div class="d-flex justify-content-between mb-2">
                                <span>Sub Total:</span>
                                <strong id="lblSubTotal">৳0.00</strong>
                            </div>
                            <div class="d-flex justify-content-between mb-2 text-success">
                                <span>Discount:</span>
                                <strong id="lblDiscount">- ৳0.00</strong>
                            </div>
                            <hr />
                            <div class="d-flex justify-content-between">
                                <span class="font-weight-bold" style="font-size: 1.2rem;">Total Amount:</span>
                                <strong class="text-primary" style="font-size: 1.2rem;" id="lblTotal">৳0.00</strong>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="form-actions mt-4 text-right">
                <button type="button" class="btn btn-outline" onclick="window.history.back()">Cancel</button>
                <button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> Create Invoice</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        let itemIndex = 0;

        function addItem() {
            const tr = document.createElement('tr');
            tr.innerHTML = `
                <td><input name="ExtraItems[${itemIndex}].Description" class="form-control form-control-sm" required /></td>
                <td><input name="ExtraItems[${itemIndex}].UnitPrice" type="number" step="0.01" class="form-control form-control-sm calc-field item-price" required /></td>
                <td><input name="ExtraItems[${itemIndex}].Quantity" type="number" min="1" value="1" class="form-control form-control-sm calc-field item-qty" required /></td>
                <td class="item-total font-weight-bold text-right pt-3">৳0.00</td>
                <td><button type="button" class="btn btn-sm btn-danger px-2 py-1" onclick="this.closest('tr').remove(); calculateTotals();"><i class="fas fa-trash"></i></button></td>
            `;
            document.querySelector('#itemsTable tbody').appendChild(tr);
            itemIndex++;
            bindCalcEvents();
        }

        function bindCalcEvents() {
            document.querySelectorAll('.calc-field').forEach(el => {
                el.removeEventListener('input', calculateTotals);
                el.addEventListener('input', calculateTotals);
            });
        }

        function calculateTotals() {
            let fixedSub = 0;
            fixedSub += parseFloat(document.getElementById('ConsultationFee').value) || 0;
            fixedSub += parseFloat(document.getElementById('TestFee').value) || 0;
            fixedSub += parseFloat(document.getElementById('OtherCharges').value) || 0;

            let itemsSub = 0;
            document.querySelectorAll('#itemsTable tbody tr').forEach(tr => {
                const price = parseFloat(tr.querySelector('.item-price').value) || 0;
                const qty = parseInt(tr.querySelector('.item-qty').value) || 1;
                const lineTotal = price * qty;
                tr.querySelector('.item-total').textContent = '৳' + lineTotal.toFixed(2);
                itemsSub += lineTotal;
            });

            const subTotal = fixedSub + itemsSub;
            const discountPct = parseFloat(document.getElementById('DiscountPercent').value) || 0;
            const discountAmt = subTotal * (discountPct / 100);
            const total = subTotal - discountAmt;

            document.getElementById('lblSubTotal').textContent = '৳' + subTotal.toFixed(2);
            document.getElementById('lblDiscount').textContent = '- ৳' + discountAmt.toFixed(2);
            document.getElementById('lblTotal').textContent = '৳' + total.toFixed(2);
        }

        document.getElementById('aptSelect').addEventListener('change', function() {
            const option = this.options[this.selectedIndex];
            if(option.value) {
                document.getElementById('patientSelect').value = option.dataset.patient;
                document.getElementById('doctorSelect').value = option.dataset.doctor;
                
                const docOpt = document.getElementById('doctorSelect').options[document.getElementById('doctorSelect').selectedIndex];
                if(docOpt) {
                    document.getElementById('consultationFee').value = docOpt.dataset.fee;
                }
                calculateTotals();
            }
        });

        bindCalcEvents();
        calculateTotals();
    </script>
}
