@model MediCareMS.Models.ViewModels.Auth.LoginViewModel
@{
    Layout = null;
    ViewData["Title"] = "Login";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" /><meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login - MediCare HMS</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="login-page">
<div class="login-wrapper">
    <div class="login-left">
        <div class="login-brand">
            <div class="login-brand-icon"><i class="fas fa-heartbeat"></i></div>
            <h1>MediCare</h1>
            <p>Hospital Management System</p>
        </div>
        <div class="login-features">
            <div class="login-feature"><i class="fas fa-calendar-check"></i><span>Smart Appointment Booking</span></div>
            <div class="login-feature"><i class="fas fa-user-md"></i><span>Doctor Management</span></div>
            <div class="login-feature"><i class="fas fa-file-medical"></i><span>Digital Prescriptions</span></div>
            <div class="login-feature"><i class="fas fa-chart-line"></i><span>Real-Time Analytics</span></div>
        </div>
    </div>
    <div class="login-right">
        <div class="login-card">
            <div class="login-header">
                <h2>Welcome Back</h2>
                <p>Sign in to your account to continue</p>
            </div>
            <form asp-controller="Auth" asp-action="Login" method="post" class="login-form">
                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success" style="background-color: #d4edda; color: #155724; padding: 10px; border-radius: 6px; margin-bottom: 15px; font-size: 0.9rem;">
                        <i class="fas fa-check-circle"></i> @TempData["Success"]
                    </div>
                }
                <div asp-validation-summary="ModelOnly" class="validation-summary"></div>
                <div class="form-group">
                    <label class="form-label"><i class="fas fa-user"></i> Username or Email</label>
                    <input asp-for="UserNameOrEmail" class="form-control" placeholder="Enter username or email" autocomplete="username" />
                    <span asp-validation-for="UserNameOrEmail" class="field-error"></span>
                </div>
                <div class="form-group">
                    <label class="form-label"><i class="fas fa-lock"></i> Password</label>
                    <div class="password-wrapper">
                        <input asp-for="Password" type="password" class="form-control" placeholder="Enter your password" id="passwordInput" autocomplete="current-password" />
                        <button type="button" class="password-toggle" onclick="togglePassword()"><i class="fas fa-eye" id="eyeIcon"></i></button>
                    </div>
                    <span asp-validation-for="Password" class="field-error"></span>
                </div>
                <div class="form-group form-check-row">
                    <label class="check-label">
                        <input asp-for="RememberMe" type="checkbox" /> Remember me
                    </label>
                </div>
                <button type="submit" class="btn btn-primary btn-login">
                    <i class="fas fa-sign-in-alt"></i> Sign In
                </button>
            </form>
            <div class="login-hint">
                <i class="fas fa-info-circle"></i> Default: <strong>admin</strong> / <strong>Admin@12345</strong>
            </div>
            <div style="text-align: center; margin-top: 15px; color: var(--text-muted); font-size: 0.9rem;">
                Don't have an account? <a asp-controller="Auth" asp-action="SignUp" style="color: var(--primary); font-weight: 600; text-decoration: none;">Sign Up</a>
            </div>
        </div>
    </div>
</div>
<script>
    function togglePassword(){
        const i=document.getElementById('passwordInput');
        const e=document.getElementById('eyeIcon');
        if(i.type==='password'){i.type='text';e.classList.replace('fa-eye','fa-eye-slash');}
        else{i.type='password';e.classList.replace('fa-eye-slash','fa-eye');}
    }
</script>
</body>
</html>
