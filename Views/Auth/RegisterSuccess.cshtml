@{
    Layout = null;
    ViewData["Title"] = "Registration Successful";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" /><meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Registered! - MediCare HMS</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <style>
        body { background:linear-gradient(135deg,#e8f0fe,#e0f7fa); min-height:100vh; display:flex; align-items:center; justify-content:center; font-family:Inter,sans-serif; }
        .card { background:#fff; border-radius:16px; padding:52px 44px; text-align:center; max-width:440px; box-shadow:0 8px 40px rgba(0,0,0,.12); }
        .icon { font-size:64px; }
        h2 { color:#1a202c; font-weight:800; margin:16px 0 8px; }
        p { color:#718096; line-height:1.7; }
        .badge { display:inline-block; background:#d4edda; color:#155724; padding:6px 18px; border-radius:20px; font-size:13px; font-weight:600; margin:16px 0; }
        a { color:#1a73e8; font-weight:600; text-decoration:none; }
    </style>
</head>
<body>
<div class="card">
    <div class="icon">✅</div>
    <h2>Registration Complete!</h2>
    <div class="badge"><i>Pending Admin Approval</i></div>
    <p>Your account has been created. An administrator will review your registration and activate your account shortly.</p>
    <p style="margin-top:16px"><a href="/Auth/Login">← Back to Login</a></p>
</div>
</body>
</html>
