@model MediCareMS.Models.Entities.Doctor.Department
@{
    ViewData["Title"] = "Department Details";
    Layout = "_Layout";
}

<div class="page-header">
    <h2><i class="fas fa-building"></i> @Model.Name <span>Department details</span></h2>
    <div class="d-flex gap-2">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary"><i class="fas fa-edit"></i> Edit</a>
        <a asp-action="Index" class="btn btn-outline"><i class="fas fa-arrow-left"></i> Back</a>
    </div>
</div>

<div class="row g-4">
    <!-- Info Card -->
    <div class="col-lg-4">
        <div class="card h-100">
            <div class="card-body text-center p-4">
                <div style="width:80px;height:80px;border-radius:20px;background:var(--primary-light);display:flex;align-items:center;justify-content:center;color:var(--primary);font-size:32px;margin:0 auto 16px;">
                    <i class="fas fa-building"></i>
                </div>
                <h3 style="font-size:20px;font-weight:800;margin-bottom:4px;">@Model.Name</h3>
                @if (Model.IsActive)
                {
                    <span class="status-badge status-available">Active</span>
                }
                else
                {
                    <span class="status-badge status-inactive">Inactive</span>
                }
                @if (!string.IsNullOrEmpty(Model.Description))
                {
                    <p class="text-muted mt-3" style="font-size:13px;">@Model.Description</p>
                }
            </div>
            <div class="card-body border-top pt-3">
                <div class="d-flex justify-content-between mb-2">
                    <span class="text-muted small">Created</span>
                    <span class="small fw-semibold">@Model.CreatedAt.ToString("MMM dd, yyyy")</span>
                </div>
                @if (Model.UpdatedAt.HasValue)
                {
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted small">Last Updated</span>
                        <span class="small fw-semibold">@Model.UpdatedAt.Value.ToString("MMM dd, yyyy")</span>
                    </div>
                }
                <div class="d-flex justify-content-between">
                    <span class="text-muted small">Total Doctors</span>
                    <span class="small fw-semibold">@Model.Doctors.Count</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Doctors in this department -->
    <div class="col-lg-8">
        <div class="card h-100">
            <div class="card-header">
                <h3><i class="fas fa-user-md"></i> Doctors in this Department</h3>
                <span class="badge" style="background:var(--primary-light);color:var(--primary);">@Model.Doctors.Count</span>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive" style="border:none;">
                    <table class="table mb-0">
                        <thead>
                            <tr>
                                <th>Doctor</th>
                                <th>Specialization</th>
                                <th>Fee</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (!Model.Doctors.Any())
                            {
                                <tr>
                                    <td colspan="4" class="text-center p-4 text-muted">
                                        <i class="fas fa-user-md fa-2x mb-2 d-block opacity-25"></i>
                                        No doctors assigned to this department yet.
                                    </td>
                                </tr>
                            }
                            @foreach (var doc in Model.Doctors.OrderBy(d => d.FullName))
                            {
                                <tr>
                                    <td>
                                        <div class="fw-semibold">@doc.FullName</div>
                                        <div class="text-muted small">@doc.DoctorNo</div>
                                    </td>
                                    <td>@(doc.Specialization?.Name ?? "—")</td>
                                    <td><strong class="text-success">৳@doc.ConsultationFee.ToString("N0")</strong></td>
                                    <td><span class="status-badge status-@doc.Status.ToString().ToLower()">@doc.Status</span></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
