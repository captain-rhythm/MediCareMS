@model IEnumerable<MediCareMS.Models.Entities.Doctor.Department>
@{
    ViewData["Title"] = "Departments";
    Layout = "_Layout";
    var search = ViewBag.Search as string;
}

<div class="page-header">
    <h2><i class="fas fa-building"></i> Departments <span>Manage clinical departments</span></h2>
    <a asp-action="Create" class="btn btn-primary"><i class="fas fa-plus"></i> New Department</a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show mb-4" role="alert">
        <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show mb-4" role="alert">
        <i class="fas fa-exclamation-circle me-2"></i>@TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- Stats -->
<div class="stats-grid mb-4">
    <div class="stat-card stat-blue">
        <div class="stat-icon"><i class="fas fa-building"></i></div>
        <div class="stat-info">
            <div class="stat-value">@Model.Count()</div>
            <div class="stat-label">Total Departments</div>
        </div>
    </div>
    <div class="stat-card stat-green">
        <div class="stat-icon"><i class="fas fa-check-circle"></i></div>
        <div class="stat-info">
            <div class="stat-value">@Model.Count(d => d.IsActive)</div>
            <div class="stat-label">Active</div>
        </div>
    </div>
    <div class="stat-card stat-orange">
        <div class="stat-icon"><i class="fas fa-user-md"></i></div>
        <div class="stat-info">
            <div class="stat-value">@Model.Sum(d => d.Doctors.Count)</div>
            <div class="stat-label">Total Doctors</div>
        </div>
    </div>
</div>

<!-- Search + Table -->
<div class="card">
    <div class="card-header">
        <h3><i class="fas fa-list"></i> Department List</h3>
        <form method="get" class="d-flex gap-2" style="margin:0;">
            <div class="search-box" style="min-width:260px;">
                <i class="fas fa-search"></i>
                <input name="search" class="form-control" placeholder="Search departments..." value="@search" />
            </div>
            <button class="btn btn-primary btn-sm">Search</button>
            @if (!string.IsNullOrEmpty(search))
            {
                <a asp-action="Index" class="btn btn-outline btn-sm">Clear</a>
            }
        </form>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive" style="border:none;">
            <table class="table mb-0">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Department Name</th>
                        <th>Description</th>
                        <th>Doctors</th>
                        <th>Status</th>
                        <th>Created</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="7" class="text-center p-5 text-muted">
                                <i class="fas fa-building fa-2x mb-2 d-block opacity-25"></i>
                                No departments found. <a asp-action="Create">Create one now.</a>
                            </td>
                        </tr>
                    }
                    @{ int i = 1; }
                    @foreach (var dept in Model)
                    {
                        <tr>
                            <td><span class="badge badge-light">@(i++)</span></td>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <div style="width:36px;height:36px;border-radius:10px;background:var(--primary-light);display:flex;align-items:center;justify-content:center;color:var(--primary);font-size:15px;flex-shrink:0;">
                                        <i class="fas fa-building"></i>
                                    </div>
                                    <strong>@dept.Name</strong>
                                </div>
                            </td>
                            <td class="text-muted" style="max-width:260px;">
                                @(dept.Description?.Length > 60 ? dept.Description[..60] + "…" : dept.Description ?? "—")
                            </td>
                            <td>
                                <span class="badge" style="background:var(--primary-light);color:var(--primary);">
                                    <i class="fas fa-user-md me-1"></i>@dept.Doctors.Count
                                </span>
                            </td>
                            <td>
                                @if (dept.IsActive)
                                {
                                    <span class="status-badge status-available">Active</span>
                                }
                                else
                                {
                                    <span class="status-badge status-inactive">Inactive</span>
                                }
                            </td>
                            <td class="text-muted">@dept.CreatedAt.ToString("MMM dd, yyyy")</td>
                            <td class="text-end">
                                <div class="d-flex gap-1 justify-content-end">
                                    <a asp-action="Details" asp-route-id="@dept.Id" class="btn btn-sm btn-outline" title="View"><i class="fas fa-eye"></i></a>
                                    <a asp-action="Edit"    asp-route-id="@dept.Id" class="btn btn-sm btn-outline" title="Edit"><i class="fas fa-edit"></i></a>
                                    <form asp-action="ToggleStatus" asp-route-id="@dept.Id" method="post" style="display:inline;">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm @(dept.IsActive ? "btn-warning-soft" : "btn-success-soft")" title="@(dept.IsActive ? "Deactivate" : "Activate")">
                                            <i class="fas @(dept.IsActive ? "fa-toggle-on" : "fa-toggle-off")"></i>
                                        </button>
                                    </form>
                                    @if (dept.Doctors.Count == 0)
                                    {
                                        <form asp-action="Delete" asp-route-id="@dept.Id" method="post" style="display:inline;"
                                              onsubmit="return confirm('Delete department \'@dept.Name\'?');">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-danger-soft" title="Delete"><i class="fas fa-trash"></i></button>
                                        </form>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
