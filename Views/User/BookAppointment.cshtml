@model MediCareMS.Models.ViewModels.User.BookAppointmentViewModel
@{
    ViewData["Title"] = "Book Appointment";
    Layout = "_Layout";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">Book an Appointment</h4>
                </div>
                <div class="card-body p-4">
                    <form asp-action="BookAppointment" method="post">
                        
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="form-label">Department</label>
                                <select asp-for="DepartmentId" asp-items="@(new SelectList(ViewBag.Departments, "Id", "Name"))" class="form-select">
                                    <option value="">-- Select Department --</option>
                                </select>
                                <span asp-validation-for="DepartmentId" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Doctor</label>
                                <select asp-for="DoctorId" asp-items="@(new SelectList(ViewBag.Doctors, "Id", "FullName"))" class="form-select">
                                    <option value="">-- Select Doctor --</option>
                                </select>
                                <span asp-validation-for="DoctorId" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="form-label">Date</label>
                                <input asp-for="AppointmentDate" type="date" class="form-control" />
                                <span asp-validation-for="AppointmentDate" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Time</label>
                                <input asp-for="AppointmentTime" type="time" class="form-control" />
                                <span asp-validation-for="AppointmentTime" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label class="form-label">Chief Complaint / Symptoms</label>
                            <textarea asp-for="Symptoms" class="form-control" rows="3" placeholder="Briefly describe your symptoms..."></textarea>
                            <span asp-validation-for="Symptoms" class="text-danger"></span>
                        </div>

                        <div class="d-grid">
                            <button type="submit" class="btn btn-primary btn-lg">Request Appointment</button>
                        </div>

                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
