@model IEnumerable<MediCareMS.Models.Entities.Prescription.Prescription>
@{
    ViewData["Title"] = "My Prescriptions";
}

<div class="card shadow-sm border-0" style="border-radius: 12px;">
    <div class="card-header bg-white border-bottom-0 pt-4 pb-0 px-4">
        <h5 class="mb-0 fw-bold"><i class="fas fa-file-medical text-primary"></i> Digital Prescriptions</h5>
        <p class="text-muted text-sm mt-1">Access all your medical prescriptions and diagnosis reports prescribed by your doctors.</p>
    </div>
    <div class="card-body p-4">
        @if (Model != null && Model.Any())
        {
            <div class="row">
                @foreach (var prescription in Model)
                {
                    <div class="col-md-6 mb-4">
                        <div class="card border border-light-subtle shadow-sm h-100" style="border-radius: 10px;">
                            <div class="card-body">
                                <div class="d-flex justify-content-between align-items-center mb-3 border-bottom pb-2">
                                    <div>
                                        <h6 class="fw-bold mb-0 text-primary">Dr. @prescription.Doctor.FullName</h6>
                                        <small class="text-muted">Apt: @prescription.Appointment.AppointmentNo</small>
                                    </div>
                                    <div class="text-end">
                                        <span class="badge bg-light text-dark border">@prescription.CreatedAt.ToString("MMM dd, yyyy")</span>
                                    </div>
                                </div>
                                <div class="mb-3">
                                    <span class="text-uppercase text-muted" style="font-size: 0.75rem; letter-spacing: 0.5px;">Diagnosis</span>
                                    <p class="mb-0 fw-medium">@prescription.Diagnosis</p>
                                </div>
                                <div>
                                    <span class="text-uppercase text-muted" style="font-size: 0.75rem; letter-spacing: 0.5px;">Notes & Instructions</span>
                                    <div class="bg-light p-3 mt-1 rounded" style="font-family: monospace; font-size: 0.9rem; white-space: pre-wrap;">
                                        @{
                                            var notes = prescription.Notes ?? prescription.FollowUpInstructions ?? "No additional instructions.";
                                            var regex = new System.Text.RegularExpressions.Regex(@"\[Attached file: (.*?)\]");
                                            var matches = regex.Matches(notes);
                                            var displayNotes = regex.Replace(notes, "").Trim();
                                        }
                                        @if (!string.IsNullOrWhiteSpace(displayNotes)) {
                                            @displayNotes
                                        }

                                        @foreach (System.Text.RegularExpressions.Match match in matches)
                                        {
                                            var fileUrl = match.Groups[1].Value;
                                            var ext = System.IO.Path.GetExtension(fileUrl).ToLower();
                                            if (ext == ".jpg" || ext == ".jpeg" || ext == ".png" || ext == ".gif")
                                            {
                                                <div class="mt-3">
                                                    <img src="@fileUrl" alt="Attachment" style="max-width: 100%; border-radius: 8px;" />
                                                </div>
                                            }
                                            else
                                            {
                                                <div class="mt-3">
                                                    <a href="@fileUrl" target="_blank" class="btn btn-sm btn-outline-primary"><i class="fas fa-file-download"></i> View Attachment</a>
                                                </div>
                                            }
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="text-center py-5 text-muted">
                <i class="fas fa-prescription-bottle-alt fa-3x mb-3" style="color: #dee2e6;"></i>
                <h4>No Prescriptions Found</h4>
                <p>You do not have any digital prescriptions on record yet.</p>
            </div>
        }
    </div>
</div>
