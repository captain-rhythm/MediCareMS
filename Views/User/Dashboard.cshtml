@model MediCareMS.Models.ViewModels.User.UserDashboardViewModel
@{
    ViewData["Title"] = "User Dashboard";
}

<div class="row mb-4">
    <div class="col-md-4">
        <div class="card p-4 text-center border-0 shadow-sm" style="border-radius: 12px; background: linear-gradient(135deg, #e0f7fa 0%, #b2ebf2 100%);">
            <h5 class="text-muted"><i class="fas fa-calendar-check text-primary"></i> Total Appointments</h5>
            <h2 class="text-primary fw-bold mt-2">@Model.TotalAppointments</h2>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card p-4 text-center border-0 shadow-sm" style="border-radius: 12px; background: linear-gradient(135deg, #fff3e0 0%, #ffe0b2 100%);">
            <h5 class="text-muted"><i class="fas fa-clock text-warning"></i> Upcoming</h5>
            <h2 class="text-warning fw-bold mt-2">@Model.UpcomingAppointments</h2>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card p-4 text-center border-0 shadow-sm" style="border-radius: 12px; background: linear-gradient(135deg, #e8f5e9 0%, #c8e6c9 100%);">
            <h5 class="text-muted"><i class="fas fa-file-medical text-success"></i> Prescriptions</h5>
            <h2 class="text-success fw-bold mt-2">@Model.TotalPrescriptions</h2>
        </div>
    </div>
</div>

<div class="card shadow-sm border-0 mb-4" style="border-radius: 12px;">
    <div class="card-body p-4 d-flex justify-content-between align-items-center bg-light rounded">
        <div>
            <h6 class="fw-bold text-muted mb-1">My Medical Profile</h6>
            <div class="d-flex gap-4 mt-2">
                <div><i class="fas fa-tint text-danger"></i> Blood Group: <strong class="text-dark">@(string.IsNullOrEmpty(Model.PatientBloodGroup) ? "—" : Model.PatientBloodGroup)</strong></div>
                <div><i class="fas fa-phone text-success"></i> Mobile: <strong class="text-dark">@(string.IsNullOrEmpty(Model.PatientMobile) ? "—" : Model.PatientMobile)</strong></div>
            </div>
        </div>
        <a asp-action="MyProfile" class="btn btn-outline-primary rounded-pill btn-sm px-3"><i class="fas fa-edit"></i> Edit Profile</a>
    </div>
</div>

<div class="card shadow-sm border-0" style="border-radius: 12px;">
    <div class="card-header bg-white border-bottom-0 pt-4 pb-0 px-4 d-flex justify-content-between align-items-center">
        <h5 class="mb-0 fw-bold"><i class="fas fa-history text-primary"></i> Recent Appointments</h5>
        <a asp-action="MyAppointments" class="btn btn-sm btn-outline-primary rounded-pill px-3">View All</a>
    </div>
    <div class="card-body p-4">
        @if (Model.RecentAppointments.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-light text-muted">
                        <tr>
                            <th>Apt. No</th>
                            <th>Doctor</th>
                            <th>Department</th>
                            <th>Date</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var apt in Model.RecentAppointments)
                        {
                            <tr>
                                <td class="fw-bold text-primary">@apt.AppointmentNo</td>
                                <td>@apt.DoctorName</td>
                                <td><span class="badge bg-secondary text-white">@apt.DepartmentName</span></td>
                                <td>@apt.Date.ToString("dd MMM yyyy")</td>
                                <td>
                                    @if (apt.Status == MediCareMS.Models.Enums.AppointmentStatus.Pending)
                                    {
                                        <span class="badge bg-warning text-dark">Pending</span>
                                    }
                                    else if (apt.Status == MediCareMS.Models.Enums.AppointmentStatus.Confirmed)
                                    {
                                        <span class="badge bg-info text-dark">Confirmed</span>
                                    }
                                    else if (apt.Status == MediCareMS.Models.Enums.AppointmentStatus.Completed)
                                    {
                                        <span class="badge bg-success">Completed</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">Cancelled</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="text-center py-5 text-muted">
                <i class="fas fa-calendar-times fa-3x mb-3 text-light"></i>
                <p>No recent appointments found.</p>
                <a asp-action="BookAppointment" class="btn btn-primary mt-2 rounded-pill px-4">Book Now</a>
            </div>
        }
    </div>
</div>
