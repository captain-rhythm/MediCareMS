@model MediCareMS.Models.ViewModels.User.UserDashboardViewModel
@{
    ViewData["Title"] = "User Dashboard";
}

<!-- Page Header -->
<div class="page-header">
    <h2>
        User Dashboard
        <span>Overview of your appointments and medical history.</span>
    </h2>
</div>

<!-- Stats Grid -->
<div class="stats-grid" style="margin-bottom: 24px;">
    <div class="stat-card stat-blue">
        <div class="stat-header">
            <span class="stat-label">Total Appointments</span>
            <div class="stat-icon"><i class="fas fa-calendar-check"></i></div>
        </div>
        <div class="stat-value">@Model.TotalAppointments</div>
    </div>
    <div class="stat-card stat-orange">
        <div class="stat-header">
            <span class="stat-label">Upcoming</span>
            <div class="stat-icon"><i class="fas fa-clock"></i></div>
        </div>
        <div class="stat-value">@Model.UpcomingAppointments</div>
    </div>
    <div class="stat-card stat-green">
        <div class="stat-header">
            <span class="stat-label">Prescriptions</span>
            <div class="stat-icon"><i class="fas fa-file-medical"></i></div>
        </div>
        <div class="stat-value">@Model.TotalPrescriptions</div>
    </div>
</div>

<!-- Profile Card -->
<div class="card" style="margin-bottom: 24px;">
    <div class="card-body" style="display:flex; justify-content:space-between; align-items:center;">
        <div>
            <h6 style="color:var(--text-muted); margin-bottom:8px; font-weight:600;">My Medical Profile</h6>
            <div style="display:flex; gap:24px;">
                <div>
                    <i class="fas fa-tint" style="color: #f87171;"></i> Blood Group: 
                    <strong style="color:#fff;">@(string.IsNullOrEmpty(Model.PatientBloodGroup) ? "—" : Model.PatientBloodGroup)</strong>
                </div>
                <div>
                    <i class="fas fa-phone" style="color: #34d399;"></i> Mobile: 
                    <strong style="color:#fff;">@(string.IsNullOrEmpty(Model.PatientMobile) ? "—" : Model.PatientMobile)</strong>
                </div>
            </div>
        </div>
        <a asp-action="MyProfile" class="btn btn-outline"><i class="fas fa-edit"></i> Edit Profile</a>
    </div>
</div>

<!-- Recent Appointments -->
<div class="card">
    <div class="card-header">
        <h3><i class="fas fa-history"></i> Recent Appointments</h3>
        <a asp-action="MyAppointments" class="btn btn-outline btn-sm">View All</a>
    </div>
    <div class="card-body" style="padding: 0;">
        @if (Model.RecentAppointments.Any())
        {
            <div class="table-responsive" style="border: none; border-radius: 0;">
                <table class="table mb-0">
                    <thead>
                        <tr>
                            <th>Apt. No</th>
                            <th>Doctor</th>
                            <th>Department</th>
                            <th>Date</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var apt in Model.RecentAppointments)
                        {
                            <tr>
                                <td style="color: var(--primary); font-weight: bold;">@apt.AppointmentNo</td>
                                <td>@apt.DoctorName</td>
                                <td><span class="badge badge-light">@apt.DepartmentName</span></td>
                                <td>@apt.Date.ToString("dd MMM yyyy")</td>
                                <td>
                                    @if (apt.Status == MediCareMS.Models.Enums.AppointmentStatus.Pending)
                                    {
                                        <span class="status-badge status-pending">Pending</span>
                                    }
                                    else if (apt.Status == MediCareMS.Models.Enums.AppointmentStatus.Confirmed)
                                    {
                                        <span class="status-badge status-info">Confirmed</span>
                                    }
                                    else if (apt.Status == MediCareMS.Models.Enums.AppointmentStatus.Completed)
                                    {
                                        <span class="status-badge status-completed">Completed</span>
                                    }
                                    else
                                    {
                                        <span class="status-badge status-cancelled">Cancelled</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="empty-state">
                <i class="fas fa-calendar-times" style="font-size: 48px; color: var(--text-muted); opacity: 0.5;"></i>
                <p>No recent appointments found.</p>
                <a asp-action="BookAppointment" class="btn btn-primary" style="margin-top: 12px;">Book Now</a>
            </div>
        }
    </div>
</div>
