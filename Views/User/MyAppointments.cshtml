@model IEnumerable<MediCareMS.Models.ViewModels.User.MyAppointmentItem>
@{
    ViewData["Title"] = "My Appointments";
}

<div class="card shadow-sm border-0" style="border-radius: 12px;">
    <div class="card-header bg-white border-bottom-0 pt-4 pb-0 px-4 d-flex justify-content-between align-items-center">
        <h5 class="mb-0 fw-bold"><i class="fas fa-calendar-alt text-primary"></i> My Appointments</h5>
        <a asp-action="BookAppointment" class="btn btn-primary rounded-pill px-4"><i class="fas fa-plus"></i> Book New</a>
    </div>
    <div class="card-body p-4">
        @if (Model.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-light text-muted">
                        <tr>
                            <th>Appointment No</th>
                            <th>Doctor</th>
                            <th>Department</th>
                            <th>Date</th>
                            <th>Status</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var apt in Model)
                        {
                            <tr>
                                <td class="fw-bold text-primary">@apt.AppointmentNo</td>
                                <td>@apt.DoctorName</td>
                                <td><span class="badge bg-secondary text-white">@apt.DepartmentName</span></td>
                                <td>@apt.Date.ToString("dd MMM yyyy")</td>
                                <td>
                                    @if (apt.Status == MediCareMS.Models.Enums.AppointmentStatus.Pending)
                                    {
                                        <span class="badge bg-warning text-dark">Pending</span>
                                    }
                                    else if (apt.Status == MediCareMS.Models.Enums.AppointmentStatus.Confirmed)
                                    {
                                        <span class="badge bg-info text-dark">Confirmed</span>
                                    }
                                    else if (apt.Status == MediCareMS.Models.Enums.AppointmentStatus.Completed)
                                    {
                                        <span class="badge bg-success">Completed</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">Cancelled</span>
                                    }
                                </td>
                                <td>
                                    @if (apt.Status == MediCareMS.Models.Enums.AppointmentStatus.Pending || apt.Status == MediCareMS.Models.Enums.AppointmentStatus.Confirmed)
                                    {
                                        <form asp-action="CancelAppointment" method="post" class="d-inline" onsubmit="return confirm('Are you sure you want to cancel this appointment?');">
                                            <input type="hidden" name="id" value="@apt.Id" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill px-3">Cancel</button>
                                        </form>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="text-center py-5 text-muted">
                <i class="fas fa-calendar-times fa-3x mb-3" style="color: #dee2e6;"></i>
                <h4>No Appointments Yet</h4>
                <p>You haven't booked any appointments. Click the button below to schedule one.</p>
                <a asp-action="BookAppointment" class="btn btn-primary mt-3 rounded-pill px-4">Book Appointment</a>
            </div>
        }
    </div>
</div>
