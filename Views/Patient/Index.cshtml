@model IEnumerable<MediCareMS.Models.ViewModels.Patient.PatientListViewModel>
@using MediCareMS.Models.Enums
@{ ViewData["Title"] = "Patients"; }

<div class="page-header">
    <h2><i class="fas fa-procedures"></i> Patient Management</h2>
    <a asp-action="Create" class="btn btn-primary"><i class="fas fa-user-plus"></i> Register Patient</a>
</div>
<div class="card">
    <div class="card-header">
        <form method="get" class="search-bar">
            <div class="search-group">
                <input name="search" value="@ViewBag.Search" placeholder="Search by name, patient no, or mobile..." class="form-control" />
                <button type="submit" class="btn btn-primary"><i class="fas fa-search"></i> Search</button>
                <a asp-action="Index" class="btn btn-outline">Reset</a>
            </div>
        </form>
    </div>
    <div class="table-responsive">
        <table class="table">
            <thead>
                <tr><th style="width:50px;">#</th><th>Patient No</th><th>Full Name</th><th>Age / Gender</th><th>Blood Group</th><th>Mobile</th><th>Total Visits</th><th>Actions</th></tr>
            </thead>
            <tbody>
            @{ int serialNo = 1; }
            @foreach (var p in Model)
            {
                <tr>
                    <td style="color:var(--text-muted);font-weight:600;">@(serialNo++)</td>
                    <td><span class="badge badge-light">@p.PatientNo</span></td>
                    <td><strong>@p.FullName</strong></td>
                    <td>@p.Age yrs / @p.Gender</td>
                    <td>@(p.BloodGroup?.ToString().Replace("_", " ") ?? "—")</td>
                    <td>@(p.MobileNumber ?? "—")</td>
                    <td><span class="badge badge-info">@p.TotalVisits visits</span></td>
                    <td class="actions-cell">
                        <a asp-action="Details" asp-route-id="@p.Id" class="btn btn-sm btn-outline" title="View"><i class="fas fa-eye"></i></a>
                        <a asp-action="Edit" asp-route-id="@p.Id" class="btn btn-sm btn-outline" title="Edit"><i class="fas fa-edit"></i></a>
                        <form asp-action="Delete" asp-route-id="@p.Id" method="post" style="display:inline" onsubmit="return confirm('Delete this patient?')">
                            <button class="btn btn-sm btn-danger" title="Delete"><i class="fas fa-trash"></i></button>
                        </form>
                    </td>
                </tr>
            }
            @if (!Model.Any())
            {
                <tr><td colspan="8" class="text-center"><div class="empty-state"><i class="fas fa-procedures"></i><p>No patients found.</p></div></td></tr>
            }
            </tbody>
        </table>
    </div>
    @await Html.PartialAsync("_Pagination")
</div>
