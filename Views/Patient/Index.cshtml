@{ ViewData["Title"] = "Patients"; }
@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery
@{
    var antiforgeryToken = Antiforgery.GetAndStoreTokens(Context).RequestToken;
}

<div class="page-header">
    <h2><i class="fas fa-procedures"></i> Patient Management</h2>
    <a asp-action="Create" class="btn btn-primary"><i class="fas fa-user-plus"></i> Register Patient</a>
</div>

<div class="card" style="padding:0;overflow:hidden;">
    <div id="patient-loading" style="text-align:center;padding:40px;color:#64748b;">
        <i class="fas fa-spinner fa-spin" style="font-size:28px;margin-bottom:10px;display:block;color:#8b5cf6;"></i>
        Loading patients...
    </div>
    <div id="patient-table" style="display:none;"></div>
    <div id="patient-error" style="display:none;text-align:center;padding:40px;color:#dc2626;font-size:14px;">
        <i class="fas fa-exclamation-triangle" style="font-size:32px;margin-bottom:10px;display:block;opacity:.6;"></i>
        <span id="patient-error-msg">Failed to load patients.</span>
    </div>
</div>

@section Scripts {
<link href="https://unpkg.com/tabulator-tables@6.3.0/dist/css/tabulator.min.css" rel="stylesheet"/>
<script src="https://unpkg.com/tabulator-tables@6.3.0/dist/js/tabulator.min.js"></script>
<style>
/* ── Tabulator skin – Patient Management ── */
#patient-table .tabulator {
    border: none !important;
    background: transparent !important;
    font-family: 'Inter', sans-serif !important;
    font-size: 13.5px !important;
    color: var(--text-primary, #1e293b) !important;
    border-radius: 0 0 12px 12px !important;
    overflow: hidden !important;
}
#patient-table .tabulator-header {
    background: linear-gradient(135deg, #6d28d9 0%, #7c3aed 40%, #4f46e5 100%) !important;
    border-bottom: none !important;
}
#patient-table .tabulator-col {
    background: transparent !important;
    border-right: 1px solid rgba(255,255,255,0.15) !important;
}
#patient-table .tabulator-col-title {
    color: #ffffff !important;
    font-weight: 700 !important;
    font-size: 12px !important;
    letter-spacing: .6px !important;
    text-transform: uppercase !important;
}
#patient-table .tabulator-col .tabulator-col-sorter .tabulator-arrow {
    border-top-color: rgba(255,255,255,0.7) !important;
    border-bottom-color: rgba(255,255,255,0.7) !important;
}
#patient-table .tabulator-col-content { padding: 10px 12px 4px !important; }

/* Header filter inputs */
#patient-table .tabulator-header-filter input,
#patient-table .tabulator-header-filter select {
    background: #ffffff !important;
    border: 1.5px solid rgba(255,255,255,0.6) !important;
    border-radius: 6px !important;
    padding: 4px 8px !important;
    font-size: 11.5px !important;
    color: #1e293b !important;
    width: 100% !important;
    outline: none !important;
    transition: border-color .2s !important;
}
#patient-table .tabulator-header-filter input:focus,
#patient-table .tabulator-header-filter select:focus { border-color: #8b5cf6 !important; }

/* Rows */
#patient-table .tabulator-row { border-bottom: 1px solid #f1f5f9 !important; transition: background .15s; }
#patient-table .tabulator-row:hover { background: #f5f3ff !important; }
#patient-table .tabulator-row.tabulator-row-even { background: #f8fafc; }
#patient-table .tabulator-cell { padding: 10px 12px !important; vertical-align: middle !important; }

/* Badges */
.tab-badge { display:inline-block; padding:2px 9px; border-radius:20px; font-size:11.5px; font-weight:600; }
.tab-badge-light { background:#ede9fe; color:#6d28d9; }
.tab-badge-blood { background:#fce7f3; color:#9d174d; }
.tab-badge-info  { background:#e0f2fe; color:#0369a1; }

/* Actions */
.tab-actions { display:flex; gap:6px; justify-content:center; }
.tab-btn {
    display:inline-flex; align-items:center; justify-content:center;
    width:30px; height:30px; border-radius:7px;
    border:none; cursor:pointer; text-decoration:none;
    transition: transform .15s, box-shadow .15s;
    background:#ede9fe; color:#6d28d9;
}
.tab-btn:hover { transform:translateY(-2px); box-shadow:0 4px 12px rgba(139,92,246,.2); }
.tab-btn-danger { background:#fee2e2; color:#dc2626; }

/* Pagination */
#patient-table .tabulator-footer { background:#fff; border-top:1px solid #e2e8f0; padding:8px 12px; }
#patient-table .tabulator-page {
    border:1.5px solid rgba(139,92,246,0.25) !important;
    border-radius:7px !important; padding:4px 10px !important;
    font-size:12px !important; font-family:'Inter',sans-serif !important;
    color:#374151 !important; background:#fff !important;
    cursor:pointer; transition:all .15s !important; margin:0 2px !important;
}
#patient-table .tabulator-page:hover { background:#ede9fe !important; transform:translateY(-1px); }
#patient-table .tabulator-page.active {
    background: linear-gradient(135deg, #8b5cf6, #a855f7) !important;
    border-color:transparent !important; color:#fff !important;
    box-shadow:0 4px 12px rgba(139,92,246,.35) !important;
}
#patient-table .tabulator-page[disabled] { opacity:.35; cursor:not-allowed; }
#patient-table .tabulator-page-size {
    border:1.5px solid rgba(139,92,246,0.2) !important;
    border-radius:8px; padding:4px 8px;
    font-size:12px; font-family:'Inter',sans-serif;
    color:#374151; background:#fff; cursor:pointer;
}
/* Empty/sort */
.tab-empty { text-align:center; padding:52px 20px; color:#94a3b8; font-size:14px; }
.tab-empty i { font-size:40px; margin-bottom:10px; opacity:.4; display:block; }
#patient-table .tabulator-col .tabulator-col-sorter { color:#a78bfa; }
</style>

<script>
(function () {
    const AF_TOKEN = '@antiforgeryToken';

    /* ── Formatters ── */
    const fmtPatNo  = c => `<span class="tab-badge tab-badge-light">${c.getValue() || ''}</span>`;
    const fmtName   = c => `<strong style="color:var(--text-primary,#1e293b)">${c.getValue() || ''}</strong>`;
    const fmtBlood  = c => {
        const v = c.getValue();
        return v ? `<span class="tab-badge tab-badge-blood">${v}</span>`
                 : `<span style="color:#cbd5e1">—</span>`;
    };
    const fmtVisits = c => `<span class="tab-badge tab-badge-info">${c.getValue()} visits</span>`;
    const fmtActions = c => {
        const row = c.getRow().getData();
        return `<div class="tab-actions">
            <a href="${row.detailUrl || '#'}" class="tab-btn" title="View"><i class="fas fa-eye"></i></a>
            <a href="${row.editUrl   || '#'}" class="tab-btn" title="Edit"><i class="fas fa-edit"></i></a>
            <button class="tab-btn tab-btn-danger" title="Delete"
                onclick="deletePatient('${row.deleteUrl || ''}')"><i class="fas fa-trash"></i></button>
        </div>`;
    };

    /* ── Numeric range filter ── */
    function numFilter(headerValue, rowValue) {
        if (!headerValue) return true;
        const h = headerValue.trim();
        if (/^>=/.test(h)) return rowValue >= parseInt(h.slice(2));
        if (/^<=/.test(h)) return rowValue <= parseInt(h.slice(2));
        if (/^>/.test(h))  return rowValue >  parseInt(h.slice(1));
        if (/^</.test(h))  return rowValue <  parseInt(h.slice(1));
        return rowValue === parseInt(h);
    }

    const bgValues = [
        { label: 'All Blood Groups', value: '' },
        { label: 'A Positive',  value: 'A Positive' },
        { label: 'A Negative',  value: 'A Negative' },
        { label: 'B Positive',  value: 'B Positive' },
        { label: 'B Negative',  value: 'B Negative' },
        { label: 'AB Positive', value: 'AB Positive' },
        { label: 'AB Negative', value: 'AB Negative' },
        { label: 'O Positive',  value: 'O Positive' },
        { label: 'O Negative',  value: 'O Negative' },
    ];

    function initTable(patients) {
        document.getElementById('patient-loading').style.display = 'none';
        document.getElementById('patient-table').style.display   = 'block';

        new Tabulator('#patient-table', {
            data:                  patients,
            layout:                'fitColumns',
            responsiveLayout:      'collapse',
            pagination:            true,
            paginationMode:        'local',
            paginationSize:        10,
            paginationSizeSelector:[5, 10, 20, 50],
            movableColumns:        false,
            sortMode:              'local',
            filterMode:            'local',
            placeholder:           `<div class="tab-empty"><i class="fas fa-procedures"></i>No patients found.</div>`,
            columns: [
                {
                    title: '#', field: 'id', width: 55,
                    hozAlign: 'center', headerHozAlign: 'center',
                    headerFilter: false, headerSort: false,
                    formatter: c => {
                        const rows = c.getTable().getRows('active');
                        return `<span style="color:#94a3b8;font-weight:600;font-size:12px">${rows.indexOf(c.getRow()) + 1}</span>`;
                    }
                },
                { title: 'Patient No',   field: 'patientNo',   minWidth: 130, headerFilter: 'input', headerFilterPlaceholder: 'Search…', formatter: fmtPatNo,  sorter: 'string' },
                { title: 'Full Name',     field: 'fullName',    minWidth: 160, headerFilter: 'input', headerFilterPlaceholder: 'Search…', formatter: fmtName,   sorter: 'string' },
                { title: 'Mobile',        field: 'mobile',      minWidth: 130, headerFilter: 'input', headerFilterPlaceholder: 'Search…', sorter: 'string' },
                { title: 'Age / Gender',  field: 'ageGender',   minWidth: 120, headerFilter: 'input', headerFilterPlaceholder: 'Search…', sorter: 'string' },
                { title: 'Blood Group',   field: 'bloodGroup',  minWidth: 130, headerFilter: 'select', headerFilterParams: { values: bgValues }, headerFilterFunc: '=', formatter: fmtBlood, sorter: 'string' },
                { title: 'Total Visits',  field: 'totalVisits', minWidth: 120, hozAlign: 'center', headerHozAlign: 'center', headerFilter: 'input', headerFilterPlaceholder: 'e.g. >5', headerFilterFunc: numFilter, formatter: fmtVisits, sorter: 'number' },
                { title: 'Actions',       field: 'id',          minWidth: 120, hozAlign: 'center', headerHozAlign: 'center', headerFilter: false, headerSort: false, formatter: fmtActions }
            ]
        });
    }

    /* ── Fetch from API ── */
    fetch('/Patient/GetList')
        .then(res => {
            if (!res.ok) throw new Error(`HTTP ${res.status}`);
            return res.json();
        })
        .then(data => initTable(Array.isArray(data) ? data : []))
        .catch(err => {
            console.error('Patient list fetch error:', err);
            document.getElementById('patient-loading').style.display = 'none';
            const errEl = document.getElementById('patient-error');
            errEl.style.display = 'block';
            document.getElementById('patient-error-msg').textContent = 'Failed to load patients: ' + err.message;
        });

    /* ── Delete helper ── */
    window.deletePatient = function (url) {
        if (!url || !confirm('Delete this patient?')) return;
        const form = document.createElement('form');
        form.method = 'post';
        form.action = url;
        const tok = document.createElement('input');
        tok.type = 'hidden'; tok.name = '__RequestVerificationToken'; tok.value = AF_TOKEN;
        form.appendChild(tok);
        document.body.appendChild(form);
        form.submit();
    };
})();
</script>
}
