@{ ViewData["Title"] = "Patients"; }
@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery
@{
    var antiforgeryToken = Antiforgery.GetAndStoreTokens(Context).RequestToken;
}

<div class="page-header">
    <h2><i class="fas fa-procedures"></i> Patient Management</h2>
    <a asp-action="Create" class="btn btn-primary"><i class="fas fa-user-plus"></i> Register Patient</a>
</div>

<div class="card" style="padding:0;overflow:hidden;">
    <div id="patient-table"></div>
</div>

<div id="patient-error" style="display:none;text-align:center;padding:40px;color:#dc2626;font-size:14px;">
    <i class="fas fa-exclamation-triangle" style="font-size:32px;margin-bottom:10px;display:block;opacity:.6;"></i>
    <span id="patient-error-msg">Failed to load patients.</span>
</div>

@section Scripts {
<link href="https://unpkg.com/tabulator-tables@6.3.0/dist/css/tabulator.min.css" rel="stylesheet"/>
<script src="https://unpkg.com/tabulator-tables@6.3.0/dist/js/tabulator.min.js"></script>
<style>
/* ── Tabulator skin – Patient Management (matches Doctor Management) ── */
#patient-table .tabulator {
    border: none !important;
    background: transparent !important;
    font-family: 'Inter', sans-serif !important;
    font-size: 13.5px !important;
    color: var(--text-primary, #1e293b) !important;
    border-radius: 0 0 12px 12px !important;
    overflow: hidden !important;
}
#patient-table .tabulator-header {
    background: linear-gradient(135deg, #0ea5e9 0%, #6366f1 50%, #8b5cf6 100%) !important;
    border-bottom: none !important;
}
#patient-table .tabulator-col {
    background: transparent !important;
    border-right: 1px solid rgba(255,255,255,0.15) !important;
}
#patient-table .tabulator-col-title {
    color: #ffffff !important;
    font-weight: 700 !important;
    font-size: 12px !important;
    letter-spacing: .6px !important;
    text-transform: uppercase !important;
}
#patient-table .tabulator-col .tabulator-col-sorter .tabulator-arrow {
    border-top-color: rgba(255,255,255,0.7) !important;
    border-bottom-color: rgba(255,255,255,0.7) !important;
}
#patient-table .tabulator-col-content { padding: 10px 12px 4px !important; }

/* Header filter inputs */
#patient-table .tabulator-header-filter input,
#patient-table .tabulator-header-filter select {
    background: #ffffff !important;
    border: 1.5px solid rgba(255,255,255,0.6) !important;
    border-radius: 6px !important;
    padding: 4px 8px !important;
    font-size: 11.5px !important;
    color: #1e293b !important;
    width: 100% !important;
    outline: none !important;
    transition: border-color .2s !important;
}
#patient-table .tabulator-header-filter input:focus,
#patient-table .tabulator-header-filter select:focus { border-color: #6366f1 !important; }

/* Rows */
#patient-table .tabulator-row { border-bottom: 1px solid #f1f5f9 !important; transition: background .15s; }
#patient-table .tabulator-row:hover { background: #f0f9ff !important; }
#patient-table .tabulator-row.tabulator-row-even { background: #f8fafc; }
#patient-table .tabulator-cell { padding: 10px 12px !important; vertical-align: middle !important; }

/* Badges */
.pat-badge           { display:inline-block; padding:2px 9px; border-radius:20px; font-size:11.5px; font-weight:600; }
.pat-badge-no        { background:#ede9fe; color:#6d28d9; }
.pat-badge-gender    { background:#e0f2fe; color:#0369a1; }
.pat-badge-blood     { background:#fce7f3; color:#9d174d; }
.pat-badge-visits    { background:#f0fdf4; color:#166534; }
.pat-badge-male      { background:#dbeafe; color:#1d4ed8; }
.pat-badge-female    { background:#fce7f3; color:#9d174d; }
.pat-badge-other     { background:#fef9c3; color:#854d0e; }

/* Actions */
.pat-actions { display:flex; gap:6px; justify-content:center; }
.pat-btn {
    display:inline-flex; align-items:center; justify-content:center;
    width:30px; height:30px; border-radius:7px;
    border:none; cursor:pointer; text-decoration:none;
    transition: transform .15s, box-shadow .15s;
}
.pat-btn:hover { transform:translateY(-2px); box-shadow:0 4px 12px rgba(0,0,0,.12); }
.pat-btn-view   { background:#ede9fe; color:#6d28d9; }
.pat-btn-edit   { background:#e0f2fe; color:#0369a1; }
.pat-btn-delete { background:#fee2e2; color:#dc2626; }

/* Pagination */
#patient-table .tabulator-footer { background:#fff; border-top:1px solid #e2e8f0; padding:8px 12px; }
#patient-table .tabulator-page {
    border:1.5px solid rgba(99,102,241,0.25) !important;
    border-radius:7px !important; padding:4px 10px !important;
    font-size:12px !important; font-family:'Inter',sans-serif !important;
    color:#374151 !important; background:#fff !important;
    cursor:pointer; transition:all .15s !important; margin:0 2px !important;
}
#patient-table .tabulator-page:hover { background:#ede9fe !important; transform:translateY(-1px); }
#patient-table .tabulator-page.active {
    background: linear-gradient(135deg,#0ea5e9,#6366f1) !important;
    border-color:transparent !important; color:#fff !important;
    box-shadow:0 4px 12px rgba(99,102,241,.35) !important;
}
#patient-table .tabulator-page[disabled] { opacity:.35; cursor:not-allowed; }
#patient-table .tabulator-page-size {
    border:1.5px solid rgba(99,102,241,0.2) !important;
    border-radius:8px; padding:4px 8px;
    font-size:12px; font-family:'Inter',sans-serif;
    color:#374151; background:#fff; cursor:pointer;
}
/* Empty state */
.pat-empty { text-align:center; padding:52px 20px; color:#94a3b8; font-size:14px; }
.pat-empty i { font-size:40px; margin-bottom:10px; opacity:.4; display:block; }
</style>

<script>
(function () {
    'use strict';

    const AF_TOKEN = '@antiforgeryToken';
    const CACHE_NS  = 'pt_cache_v2';
    const CACHE_TTL = 60_000;

    /* ── Session-storage micro-cache ───────────────────────────────────────── */
    function cacheKey(p)  { return CACHE_NS + '|' + JSON.stringify(p); }
    function cacheGet(k)  {
        try {
            const raw = sessionStorage.getItem(k);
            if (!raw) return null;
            const { ts, data } = JSON.parse(raw);
            if (Date.now() - ts > CACHE_TTL) { sessionStorage.removeItem(k); return null; }
            return data;
        } catch { return null; }
    }
    function cacheSet(k, d) {
        try { sessionStorage.setItem(k, JSON.stringify({ ts: Date.now(), data: d })); } catch {}
    }

    /* ── Formatters ─────────────────────────────────────────────────────────── */
    const fmtPatNo = c => `<span class="pat-badge pat-badge-no">${c.getValue() || ''}</span>`;
    const fmtName  = c => `<strong style="color:var(--text-primary,#1e293b)">${c.getValue() || ''}</strong>`;
    const fmtMobile= c => `<span style="color:#475569;font-weight:500">${c.getValue() || '—'}</span>`;
    const fmtAge   = c => {
        const v = c.getValue() || '';
        return `<span style="color:#475569;font-weight:600">${v}</span>`;
    };
    const fmtBlood = c => {
        const v = c.getValue();
        return v ? `<span class="pat-badge pat-badge-blood">${v}</span>`
                 : `<span style="color:#cbd5e1">—</span>`;
    };
    const fmtVisits = c => {
        const n = c.getValue() ?? 0;
        return `<span class="pat-badge pat-badge-visits">${n} visit${n !== 1 ? 's' : ''}</span>`;
    };
    const fmtActions = c => {
        const row = c.getRow().getData();
        return `<div class="pat-actions">
            <a href="${row.detailUrl || '#'}" class="pat-btn pat-btn-view" title="View"><i class="fas fa-eye"></i></a>
            <a href="${row.editUrl   || '#'}" class="pat-btn pat-btn-edit" title="Edit"><i class="fas fa-edit"></i></a>
            <button class="pat-btn pat-btn-delete" title="Delete"
                onclick="deletePatient('${row.deleteUrl || ''}')"><i class="fas fa-trash"></i></button>
        </div>`;
    };

    const bgValues = [
        { label: 'All Blood Groups', value: '' },
        { label: 'A Positive',  value: 'A Positive'  },
        { label: 'A Negative',  value: 'A Negative'  },
        { label: 'B Positive',  value: 'B Positive'  },
        { label: 'B Negative',  value: 'B Negative'  },
        { label: 'AB Positive', value: 'AB Positive' },
        { label: 'AB Negative', value: 'AB Negative' },
        { label: 'O Positive',  value: 'O Positive'  },
        { label: 'O Negative',  value: 'O Negative'  },
    ];

    /* ── Custom AJAX handler with session-storage cache ─────────────────────── */
    function ajaxRequestFunc(url, config, params) {
        const req = {
            page:       params.page          ?? 1,
            pageSize:   params.size           ?? 10,
            search:     '',
            bloodGroup: '',
            sortField:  params.sorters?.[0]?.field ?? 'fullName',
            sortDir:    params.sorters?.[0]?.dir   ?? 'asc',
        };

        if (params.filters) {
            for (const f of params.filters) {
                if (['patientNo', 'fullName', 'mobile'].includes(f.field))
                    req.search = f.value || '';
                if (f.field === 'bloodGroup')
                    req.bloodGroup = f.value || '';
            }
        }

        const ck  = cacheKey(req);
        const hit = cacheGet(ck);
        if (hit) return Promise.resolve(hit);

        const qs = new URLSearchParams({
            page:       req.page,
            pageSize:   req.pageSize,
            search:     req.search,
            bloodGroup: req.bloodGroup,
            sortField:  req.sortField,
            sortDir:    req.sortDir,
        });

        return fetch(`/Patient/GetPagedList?${qs}`, { credentials: 'same-origin' })
            .then(r => r.json())
            .then(resp => {
                const normalized = {
                    data:      resp.data,
                    last_page: Math.max(1, Math.ceil(resp.total / req.pageSize)),
                    _total:    resp.total
                };
                cacheSet(ck, normalized);
                return normalized;
            })
            .catch(err => {
                console.error('[PatientTable] fetch error', err);
                document.getElementById('patient-error').style.display = '';
                document.getElementById('patient-error-msg').textContent = 'Failed to load patients. Please refresh.';
                return { data: [], last_page: 1, _total: 0 };
            });
    }

    /* ── Initialise Tabulator ─────────────────────────────────────────────── */
    new Tabulator('#patient-table', {
        ajaxURL:             '/Patient/GetPagedList',
        ajaxRequestFunc:     ajaxRequestFunc,
        layout:              'fitColumns',
        responsiveLayout:    'collapse',
        pagination:          true,
        paginationMode:      'remote',
        filterMode:          'remote',
        sortMode:            'remote',
        paginationSize:      10,
        paginationSizeSelector: [5, 10, 20, 50],
        movableColumns:      false,
        ajaxResponse(url, params, response) { return response; },
        placeholder: `<div class="pat-empty"><i class="fas fa-procedures"></i>No patients found.</div>`,
        columns: [
            {
                title: '#', field: 'id', width: 55,
                hozAlign: 'center', headerHozAlign: 'center',
                headerFilter: false, headerSort: false,
                formatter: c => {
                    const rows = c.getTable().getRows('active');
                    return `<span style="color:#94a3b8;font-weight:600;font-size:12px">${rows.indexOf(c.getRow()) + 1}</span>`;
                }
            },
            { title: 'Patient No',  field: 'patientNo',  minWidth: 130, headerFilter: 'input', headerFilterPlaceholder: 'Search…', formatter: fmtPatNo,  sorter: 'string' },
            { title: 'Full Name',   field: 'fullName',   minWidth: 160, headerFilter: 'input', headerFilterPlaceholder: 'Search…', formatter: fmtName,   sorter: 'string' },
            { title: 'Mobile',      field: 'mobile',     minWidth: 130, headerFilter: 'input', headerFilterPlaceholder: 'Search…', formatter: fmtMobile, sorter: 'string' },
            { title: 'Age / Gender',field: 'ageGender',  minWidth: 130, headerFilter: false,  formatter: fmtAge,    sorter: 'string' },
            { title: 'Blood Group', field: 'bloodGroup', minWidth: 130, headerFilter: 'select', headerFilterParams: { values: bgValues }, headerFilterFunc: '=', formatter: fmtBlood, sorter: 'string' },
            { title: 'Total Visits',field: 'totalVisits',minWidth: 120, hozAlign: 'center', headerHozAlign: 'center', headerFilter: false, formatter: fmtVisits, sorter: 'number' },
            { title: 'Actions',     field: 'id',         minWidth: 120, hozAlign: 'center', headerHozAlign: 'center', headerFilter: false, headerSort: false, formatter: fmtActions }
        ]
    });

    /* ── Delete helper ────────────────────────────────────────────────────── */
    window.deletePatient = function (url) {
        if (!url || !confirm('Delete this patient? This action cannot be undone.')) return;
        try {
            Object.keys(sessionStorage)
                .filter(k => k.startsWith(CACHE_NS))
                .forEach(k => sessionStorage.removeItem(k));
        } catch {}
        const form = document.createElement('form');
        form.method = 'post';
        form.action = url;
        const tok = document.createElement('input');
        tok.type = 'hidden'; tok.name = '__RequestVerificationToken'; tok.value = AF_TOKEN;
        form.appendChild(tok);
        document.body.appendChild(form);
        form.submit();
    };
})();
</script>
}
